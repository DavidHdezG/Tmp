---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScrollReveal from '../components/gsap/ScrollReveal.astro';
import ArtistCard from '../components/ui/ArtistCard.astro';
import { getPublishedArtists } from '../lib/directus';

const artists = await getPublishedArtists();
const registerUrl = import.meta.env.FORM_REGISTER_URL || '#';
---

<BaseLayout
  title="Artist Showcase"
  description="Meet the talented Latino and non-Latino artists creating incredible work in Amarillo and the Texas Panhandle."
>

  <section class="min-h-[40vh] bg-[#1a1a1a] flex items-end relative overflow-hidden">
    <div class="absolute inset-0">
      <img src="/background.jpg" alt="" class="w-full h-full object-cover opacity-20" aria-hidden="true" />
    </div>
    <div class="absolute left-0 top-0 bottom-0 w-1.5 bg-primary"></div>
    <div class="container relative z-10 pb-16 pt-28">
      <p class="font-sans text-xs font-semibold tracking-widest uppercase text-primary mb-4">Community</p>
      <h1 class="font-serif text-white">Artist Showcase</h1>
      <p class="font-sans text-white/70 text-xl mt-4 max-w-xl">Celebrating Latino Talent in the Texas Panhandle</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {artists.length > 0 ? (
        <>
          <p class="text-text-muted max-w-2xl mb-12">
            Meet the talented Latino and non-Latino artists creating incredible work and contributing to the vibrant cultural landscape of Amarillo and the Texas Panhandle.
          </p>
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            {artists.map(artist => <ArtistCard artist={artist} />)}
          </div>
        </>
      ) : (
        <div class="text-center py-24">
          <p class="font-serif text-2xl text-text-muted mb-4">Artists coming soon.</p>
          <p class="text-text-muted">We're building our artist directory. Register below to be featured.</p>
        </div>
      )}
    </div>
  </section>

  <ScrollReveal selector=".artist-card" from="bottom" stagger={0.08} />

  <section class="section section--dark text-center">
    <div class="container">
      <h2 class="font-serif text-white mb-4">Are You an Artist?</h2>
      <p class="text-white/70 max-w-xl mx-auto mb-8">
        Register with ACLA to showcase your work, connect with audiences, and participate in our programs and events.
      </p>
      <a href={registerUrl} class="btn btn--primary" target="_blank" rel="noopener noreferrer">
        Register as an Artist
      </a>
    </div>
  </section>

</BaseLayout>