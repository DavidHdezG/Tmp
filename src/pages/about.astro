---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScrollReveal from '../components/gsap/ScrollReveal.astro';

const registerUrl = import.meta.env.FORM_REGISTER_URL || '#';

const MISSION_ITEMS = [
  'Providing scholarships and financial support to Latino artists',
  'Creating platforms for performances, exhibitions, and artistic expression',
  'Fostering community engagement through cultural events',
  'Building bridges between artists and audiences',
  'Preserving and promoting Latino cultural traditions',
];

const VISION_ITEMS = [
  'Artists have access to resources and opportunities',
  'Latino culture is celebrated and respected',
  'Diverse communities come together through art',
  'Future generations inherit a rich cultural legacy',
  'Artistic excellence is nurtured and supported',
];

const PROGRAMS = [
  { title: 'Artist Scholarships', description: 'Financial support to emerging and established Latino artists to advance their artistic education and career development.', href: '/scholarships', cta: 'Learn More' },
  { title: 'Performances & Exhibitions', description: 'ACLA creates platforms for artists through concerts, theater, dance performances, and visual art exhibitions.', href: '/events', cta: 'View Events' },
  { title: 'Artist Showcase', description: 'Our gallery features talented Latino artists, connecting them with audiences and potential collaborators.', href: '/artists', cta: 'View Artists' },
  { title: 'Community Engagement', description: 'Through workshops, educational programs, and community events, we engage residents of all ages in Latino culture.', href: '/events', cta: 'Upcoming Events' },
];
---

<BaseLayout
  title="About ACLA — Latino Arts Council in Amarillo, TX"
  description="Amarillo's 501(c)(3) nonprofit for Latino arts — $100K+ in scholarships awarded, 500+ artists supported, and 50+ annual cultural events in the Texas Panhandle."
  ogImage="/acla-community.jpg"
>

  <section class="min-h-[45vh] bg-[#1a1a1a] flex items-end relative overflow-hidden">
    <div class="absolute inset-0">
      <img src="/background.jpg" alt="" class="w-full h-full object-cover opacity-20" aria-hidden="true" />
    </div>
    <div class="absolute left-0 top-0 bottom-0 w-1.5 bg-primary"></div>
    <div class="container relative z-10 pb-16 pt-28">
      <p class="font-sans text-xs font-semibold tracking-widest uppercase text-primary mb-4">Who We Are</p>
      <h1 class="font-serif text-white">About ACLA</h1>
      <p class="font-sans text-white/70 text-xl mt-4 max-w-xl">
        Empowering Latino Arts and Culture in the Texas Panhandle
      </p>
    </div>
  </section>

  <!-- MISSION & VISION -->
  <section class="section">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-16">
        <div class="about-block">
          <p class="font-sans text-xs font-semibold tracking-widest uppercase text-primary mb-4">Mission</p>
          <h2 class="font-serif mb-6">Our Mission</h2>
          <p class="text-text-muted mb-6">To support, promote, and celebrate Latino arts and cultural heritage in the Texas Panhandle by:</p>
          <ul class="space-y-3 list-none p-0">
            {MISSION_ITEMS.map(item => (
              <li class="flex gap-3 text-text-muted">
                <span class="text-primary font-bold mt-0.5 shrink-0">—</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="about-block">
          <p class="font-sans text-xs font-semibold tracking-widest uppercase text-primary mb-4">Vision</p>
          <h2 class="font-serif mb-6">Our Vision</h2>
          <p class="text-text-muted mb-6">To establish the Texas Panhandle as a vibrant hub for Latino arts where:</p>
          <ul class="space-y-3 list-none p-0">
            {VISION_ITEMS.map(item => (
              <li class="flex gap-3 text-text-muted">
                <span class="text-primary font-bold mt-0.5 shrink-0">—</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <ScrollReveal selector=".about-block" from="bottom" stagger={0.15} />

  <!-- STORY -->
  <section class="section bg-[#1a1a1a]">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <p class="font-sans text-xs font-semibold tracking-widest uppercase text-primary mb-4">History</p>
        <h2 class="font-serif text-white mb-8">Our Story</h2>
        <p class="text-white/70 leading-relaxed mb-6 text-lg">
          Founded in response to the need for greater support and visibility of Latino artists in Amarillo and the Texas Panhandle, ACLA emerged from the vision of community leaders, artists, and cultural advocates who recognized the rich Latino heritage of our region.
        </p>
        <p class="text-white/60 leading-relaxed mb-6">
          Since our inception, we have been committed to creating meaningful opportunities for Latino and non-Latino artists to share their talents, celebrate cultural traditions, and contribute to the vibrant artistic community in Amarillo.
        </p>
        <p class="text-white/60 leading-relaxed m-0">
          Through partnerships with local organizations, schools, and cultural institutions, ACLA has grown to become a trusted voice for the arts in our community, supporting hundreds of artists with scholarships, performance opportunities, and exhibition space.
        </p>
      </div>
    </div>
  </section>

  <!-- IMPACT STATS -->
  <section class="section bg-primary">
    <div class="container">
      <div class="grid grid-cols-3 gap-8 text-center">
        {[
          { n: '500+', l: 'Artists Supported', sub: 'Through scholarships, grants, and performance opportunities' },
          { n: '$100K+', l: 'Scholarships Awarded', sub: 'Invested directly in artist development and education' },
          { n: '50+', l: 'Annual Events', sub: 'Festivals, exhibitions, performances, and workshops' },
        ].map(s => (
          <div class="stat-block">
            <p class="font-serif text-5xl font-bold text-white mb-2 m-0">{s.n}</p>
            <p class="font-sans font-semibold text-white text-xs uppercase tracking-widest mb-2 m-0">{s.l}</p>
            <p class="text-white/60 text-xs m-0">{s.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <ScrollReveal selector=".stat-block" from="bottom" stagger={0.1} />

  <!-- PROGRAMS -->
  <section class="section">
    <div class="container">
      <div class="text-center mb-12">
        <p class="font-sans text-xs font-semibold tracking-widest uppercase text-primary mb-4">What We Do</p>
        <h2 class="font-serif">Our Programs</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        {PROGRAMS.map(p => (
          <div class="program-block border border-border p-8 hover:border-primary transition-colors duration-300">
            <h3 class="font-serif text-xl mb-4">{p.title}</h3>
            <p class="text-text-muted leading-relaxed mb-6">{p.description}</p>
            <a href={p.href} class="btn btn--primary">{p.cta}</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <ScrollReveal selector=".program-block" from="bottom" stagger={0.1} />

  <section class="section section--dark text-center">
    <div class="container">
      <h2 class="font-serif text-white mb-4">Join Us in Supporting Latino Arts</h2>
      <p class="text-white/70 max-w-xl mx-auto mb-8">Whether you're an artist, patron, or community member, there are many ways to get involved.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href={registerUrl} class="btn btn--primary" target="_blank" rel="noopener noreferrer">Register as an Artist</a>
        <a href="/donate" class="btn btn--outline" style="border-color:white;color:white;">Support Our Mission</a>
      </div>
    </div>
  </section>

</BaseLayout>