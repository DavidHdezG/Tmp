---
interface Props {
  selector: string;
  from?: 'bottom' | 'left' | 'right';
  stagger?: number;
}
// Note: ScrollTrigger.batch() is used here for performance (gsap-scrolltrigger + gsap-performance skills)
// Batch collects all matching elements entering the viewport and animates them together with stagger
const { selector, from = 'bottom', stagger = 0.08 } = Astro.props;
---

<script define:vars={{ selector, from, stagger }}>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  // ScrollTrigger already registered in PageTransition.astro — no need to re-register

  const fromVars = {
    bottom: { y: 50, autoAlpha: 0 },  // gsap-core: autoAlpha not opacity
    left:   { x: -50, autoAlpha: 0 },
    right:  { x: 50, autoAlpha: 0 },
  };

  // gsap-core skill: matchMedia for prefers-reduced-motion
  const mm = gsap.matchMedia();
  mm.add('(prefers-reduced-motion: no-preference)', () => {
    // gsap-scrolltrigger skill: ScrollTrigger.batch() is more efficient than
    // individual ScrollTriggers for lists of cards/items
    ScrollTrigger.batch(selector, {
      onEnter: (elements) => {
        gsap.fromTo(elements, fromVars[from], {
          y: 0,
          x: 0,
          autoAlpha: 1,
          duration: 0.7,
          ease: 'power2.out',
          stagger,  // gsap-performance: stagger on batch, not separate tweens
        });
      },
      start: 'top 88%',
      once: true, // gsap-scrolltrigger: kill after first trigger, no ongoing overhead
    });
  });
</script>