<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  // Register once here — all other GSAP components rely on this (gsap-scrolltrigger skill)
  gsap.registerPlugin(ScrollTrigger);

  // gsap-core skill: use matchMedia for prefers-reduced-motion
  const mm = gsap.matchMedia();
  mm.add(
    {
      reduceMotion: '(prefers-reduced-motion: reduce)',
      noReduceMotion: '(prefers-reduced-motion: no-preference)',
    },
    (context) => {
      const { reduceMotion } = context.conditions || {};
      // gsap-core skill: autoAlpha instead of opacity (hides element from pointer events at 0)
      gsap.fromTo(
        '#main-content',
        { autoAlpha: reduceMotion ? 1 : 0 },
        { autoAlpha: 1, duration: reduceMotion ? 0 : 0.4, ease: 'power1.out' }
      );
    }
  );
</script>