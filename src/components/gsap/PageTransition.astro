<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  /*
    CSS en BaseLayout ya ocultó #main-content con opacity:0 antes de pintar.
    Aquí solo necesitamos animarlo a visible — sin fromTo, sin lógica de estado inicial.
    prefers-reduced-motion y noscript están cubiertos por el CSS del layout.
  */
  const mm = gsap.matchMedia();
  mm.add('(prefers-reduced-motion: no-preference)', () => {
    gsap.to('#main-content', {
      opacity: 1,
      duration: 0.45,
      ease: 'power1.out',
    });
  });
</script>
