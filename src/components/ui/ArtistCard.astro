---
import type { Artist } from '../../lib/types';
import { getAssetUrl } from '../../lib/directus';

interface Props { artist: Artist }
const { artist } = Astro.props;

const photoUrl = artist.photo
  ? getAssetUrl(
      typeof artist.photo === 'string' ? artist.photo : artist.photo.id,
      { width: 500, height: 500, fit: 'cover' }
    )
  : 'https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=500&h=500&fit=crop';
---

<article
  class="artist-card bg-white border border-border overflow-hidden group cursor-pointer"
  role="button"
  tabindex="0"
  data-artist-modal={JSON.stringify({
    type: 'artist',
    name: artist.name,
    artistType: artist.type,
    bio: artist.bio,
    photo: photoUrl,
    website: artist.website,
  })}
>
  <div class="overflow-hidden aspect-square">
    <img
      src={photoUrl}
      alt={artist.name}
      width="500"
      height="500"
      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
      loading="lazy"
    />
  </div>
  <div class="p-6">
    <h3 class="font-serif text-xl mb-1 text-text-dark">{artist.name}</h3>
    <p class="font-sans text-sm font-medium text-primary mb-3 m-0">{artist.type}</p>
    <p class="text-text-muted text-sm leading-relaxed line-clamp-3">{artist.bio}</p>
    {artist.website && (
      <span class="inline-block mt-4 font-sans text-xs font-semibold tracking-wider uppercase text-primary border-b border-primary pb-0.5">
        View Profile →
      </span>
    )}
  </div>
</article>

<script>
  document.querySelectorAll<HTMLElement>('[data-artist-modal]').forEach(el => {
    const open = () => {
      const detail = JSON.parse(el.dataset.artistModal!);
      window.dispatchEvent(new CustomEvent('open-card-modal', { detail }));
    };
    el.addEventListener('click', open);
    el.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); open(); } });
  });
</script>