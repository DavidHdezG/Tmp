---
import '../styles/global.css';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import PageTransition from '@/components/gsap/PageTransition.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'The Amarillo Council for the Latino Arts supports Latino arts and cultural heritage in the Texas Panhandle through scholarships, performances, and community events.',
  ogImage = '/Logos/ACLA_Logo_Black.png',
} = Astro.props;

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://aclatx.org';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const fullTitle = `${title} | ACLA — Amarillo Council for the Latino Arts`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/Logos/ACLA_Logo_Black.png" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <!-- ui-ux-pro-max skill: skip-link for keyboard/screen reader accessibility -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[9999] focus:px-4 focus:py-2 focus:bg-primary focus:text-white focus:font-sans focus:text-sm"
    >
      Skip to main content
    </a>
    <PageTransition />
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>