# Directus CMS (internal Docker network URL)
DIRECTUS_URL=http://directus:8055
DIRECTUS_TOKEN=your-static-token-here

# External Form Links
FORM_REGISTER_URL=https://your-artist-registration-form.com
FORM_CONTACT_URL=https://your-contact-form.com

# Site public URL
PUBLIC_SITE_URL=https://aclatx.org

# Directus Bootstrap (only needed at first docker compose up)
DIRECTUS_KEY=replace-with-random-uuid
DIRECTUS_SECRET=replace-with-random-secret-string
DIRECTUS_ADMIN_EMAIL=admin@aclatx.org
DIRECTUS_ADMIN_PASSWORD=change-this-strong-password

# PostgreSQL
POSTGRES_PASSWORD=change-this-strong-password